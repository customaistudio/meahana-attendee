# Backend Environment Variables

# Frontend API URL (for CORS)


# Backend Environment Configuration
APP_NAME=Meeting Bot Service
ENVIRONMENT=production
DEBUG=false

# Service API Key (REQUIRED - Meahana Backend uses this to authenticate requests)
MEAHANA_API_KEY=your_api_key_here

# Supabase Configuration (REQUIRED)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Redis (Optional - use Railway Redis addon or external service)
REDIS_URL=redis://localhost:6379/0

# API Keys (REQUIRED)
ATTENDEE_API_KEY=your_attendee_api_key_here
ATTENDEE_API_BASE_URL=https://app.attendee.dev

# Webhook Configuration (REQUIRED for production)
# Set this to your Railway app URL, e.g., https://your-app.up.railway.app
WEBHOOK_BASE_URL=

# Outgoing Report Webhook (Optional)
# URL to POST meeting reportcards to after analysis completes
# REPORT_WEBHOOK_URL=https://your-endpoint.example.com/webhook
# HMAC-SHA256 secret for signing outgoing payloads (receiver can verify authenticity)
# REPORT_WEBHOOK_SIGNING_SECRET=your_signing_secret_here
# REPORT_WEBHOOK_TIMEOUT=10
# REPORT_WEBHOOK_MAX_RETRIES=3

# Ngrok Configuration (Development only - not needed for Railway)
# NGROK_AUTH_TOKEN=
# AUTO_START_NGROK=false
# NGROK_PORT=8000
