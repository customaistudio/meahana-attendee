# =============================================================================
# Meahana Attendee - Environment Variables
# =============================================================================

# Backend Environment Configuration
APP_NAME=Meahana Attendee
ENVIRONMENT=production
DEBUG=false

# Service API Key (REQUIRED - Meahana Backend uses this to authenticate requests)
MEAHANA_API_KEY=your_api_key_here

# Supabase Configuration (REQUIRED)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# API Keys (REQUIRED)
ATTENDEE_API_KEY=your_attendee_api_key_here
ATTENDEE_API_BASE_URL=https://app.attendee.dev

# OpenAI (REQUIRED - for meeting leadership scorecards)
OPENAI_API_KEY=your_openai_api_key_here

# Webhook Configuration (REQUIRED)
# Production: https://assistant-dev.meahana.io
WEBHOOK_BASE_URL=https://assistant-dev.meahana.io

# Outgoing Report Webhook (Optional - URL to POST scorecards to)
# REPORT_WEBHOOK_URL=https://your-meahana-backend/webhook/scorecard
# REPORT_WEBHOOK_SIGNING_SECRET=your_signing_secret_here

# =============================================================================
# Development Only (not needed for production)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0
# NGROK_AUTH_TOKEN=
# AUTO_START_NGROK=false
# NGROK_PORT=8000
